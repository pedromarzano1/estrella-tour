# ─── BASE DE DATOS (Supabase) ──────────────────────────────────────────────────
# Obtenés estos valores en: supabase.com → Tu proyecto → Settings → Database
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://tu-dominio.vercel.app"
# En desarrollo: http://localhost:3000

# ─── MERCADO PAGO ──────────────────────────────────────────────────────────────
# Obtené tus credenciales en: mercadopago.com.ar → Tu negocio → Credenciales
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxx-xxxxxxxx"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# Secreto del webhook (lo configurás en el panel de MP cuando registrás el webhook)
MP_WEBHOOK_SECRET="tu_secreto_del_webhook"

# ─── EMAIL (Resend) ────────────────────────────────────────────────────────────
# Creá cuenta gratis en: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Email desde donde se mandan las confirmaciones (debe estar verificado en Resend)
FROM_EMAIL="reservas@estrellatour.com.ar"
# Email del admin que recibe notificaciones de pagos
ADMIN_EMAIL="estrealltour.soporte@gmail.com"

# ─── SEED (solo para desarrollo / primer deploy) ───────────────────────────────
# Usadas únicamente al correr: npx prisma db seed
# NUNCA hardcodear estos valores en el código
SEED_ADMIN_EMAIL="admin@tudominio.com"
SEED_ADMIN_PASSWORD="una-contrasena-segura-y-unica"
